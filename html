<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Ultimate PDF Tool | MANGALSINGH</title>
<script src="https://accounts.google.com/gsi/client" async defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap');
:root{--ink:#0a0a0a;--paper:#f5f0e8;--accent:#ff4d1c;--card:#fff;--border:#e0d8cc;--muted:#8a8078;--green:#059669;}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{background:var(--paper);color:var(--ink);font-family:'DM Sans',sans-serif;min-height:100vh; overflow-x: hidden;}

/* --- AUTH & USER PILL --- */
#authOverlay {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: var(--paper); display: flex; align-items: center; justify-content: center;
  z-index: 2000; transition: transform 0.6s cubic-bezier(0.87, 0, 0.13, 1);
}
.auth-card { width: 92%; max-width: 380px; text-align: center; padding: 2.5rem 1.5rem; background: var(--card); border: 3px solid var(--ink); border-radius: 30px; box-shadow: 12px 12px 0px var(--ink); }
.user-pill { display: flex; align-items: center; gap: 8px; background: white; padding: 5px 12px; border-radius: 50px; border: 1.5px solid var(--ink); font-size: 0.75rem; font-weight: 700; cursor: pointer; transition: 0.2s; }
.user-pill:hover { background: #fee2e2; }
.user-pill img { width: 22px; height: 22px; border-radius: 50%; }

header{padding:.9rem 1.2rem;display:flex;align-items:center;justify-content:space-between;border-bottom:2px solid var(--ink);background:var(--paper);position:sticky;top:0;z-index:10;}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1.3rem;letter-spacing:-.04em;}

/* --- WRAPPER & DZ --- */
.wrap{max-width:540px;margin:0 auto;padding:1.4rem 1rem 2rem;}
h1{font-family:'Syne',sans-serif;font-weight:800;font-size:1.75rem;line-height:1.1;letter-spacing:-.03em;margin-bottom:1rem;}
.dz{border:2.5px dashed var(--border);border-radius:14px;padding:2.2rem 1rem;text-align:center;background:var(--card);cursor:pointer;}

/* --- FEEDBACK STYLES --- */
.comm-box { margin-top: 3rem; background: #fff; padding: 1.2rem; border: 2px solid var(--border); border-radius: 20px; }
.comm-list { max-height: 300px; overflow-y: auto; margin-bottom: 1rem; }
.comm-item { padding: 12px 0; border-bottom: 1px solid #f0f0f0; }
.comm-item strong { font-size: 0.8rem; color: var(--accent); display: block; }
.comm-item p { font-size: 0.9rem; margin-top: 4px; color: var(--ink); }
#feedbackInputArea { display: none; margin-top: 15px; border-top: 1px solid #eee; padding-top: 15px; }

.cbtn{width:100%;padding:1rem;background:var(--ink);color:var(--paper);border:none;border-radius:12px;font-family:'Syne',sans-serif;font-weight:700;cursor:pointer; margin-top: 10px;}
footer { text-align: center; padding: 3rem 1rem; border-top: 1px solid var(--border); margin-top: 2rem; }
.dev-name { font-family: 'Syne'; font-size: 1rem; color: var(--accent); text-decoration: none; font-weight: 800; }
</style>
</head>
<body>

<div id="authOverlay">
  <div class="auth-card">
    <div style="font-size: 3rem; margin-bottom: 1rem;">🚀</div>
    <h2 style="font-family:'Syne';">MANGAL <span style="color:var(--accent)">PDF</span></h2>
    <p style="color:var(--muted); font-size: 0.85rem; margin: 1rem 0 2rem;">Security ke liye login karein.</p>
    <div id="g_id_onload"
         data-client_id="952256750591-h5oi07sbio6g0q86acptsktlq85d8pt0.apps.googleusercontent.com"
         data-callback="onSignIn">
    </div>
    <div class="g_id_signin" data-type="standard" data-shape="pill"></div>
    <button onclick="skipAuth()" style="margin-top: 1.5rem; background:none; border:none; color:var(--muted); text-decoration:underline; font-size: 0.8rem; cursor:pointer;">Guest Mode &rarr;</button>
  </div>
</div>

<header>
  <div class="logo">MANGAL<span>SINGH</span></div>
  <div id="userProfile"></div>
</header>

<div class="wrap">
  <h1><em>HD Quality</em><br>PDF Creator</h1>
  
  <div class="dz" onclick="document.getElementById('fi').click()">
    <div style="font-size: 2.5rem; margin-bottom: 0.5rem;">📁</div>
    <div style="font-family:'Syne'; font-weight:700;">Files Select Karein</div>
  </div>
  <input type="file" id="fi" multiple accept="image/*" style="display:none">

  <div class="comm-box">
    <h3 style="font-family:'Syne'; font-size: 0.95rem; margin-bottom: 1rem;">User Reviews 💬</h3>
    <div class="comm-list" id="commList"></div>
    
    <div id="feedbackInputArea">
      <textarea id="uMsg" placeholder="Aapko kaisa laga?" style="width:100%; height:70px; padding:12px; border-radius:12px; border:1.5px solid var(--border); font-family:inherit; font-size: 0.9rem;"></textarea>
      <button class="cbtn" onclick="postComm()">Post Review</button>
    </div>
    <p id="guestMsg" style="font-size: 0.75rem; color: var(--muted); text-align: center; display: block;">Review dene ke liye Login karein.</p>
  </div>

  <footer>
    <p style="font-size: 0.6rem; color:var(--muted); letter-spacing: 2px;">DEVELOPED BY</p>
    <a href="#" class="dev-name">MANGALSINGH</a>
  </footer>
</div>

<script>
let currentUser = null;

function skipAuth() {
  document.getElementById('authOverlay').style.transform = 'translateY(-100%)';
}

function onSignIn(response) {
  const data = JSON.parse(atob(response.credential.split('.')[1]));
  currentUser = { name: data.name, pic: data.picture, email: data.email };
  
  // Update Header with Logout option
  document.getElementById('userProfile').innerHTML = `
    <div class="user-pill" onclick="logout()" title="Logout">
      <img src="${currentUser.pic}"> ${currentUser.name.split(' ')[0]}
    </div>
  `;
  
  document.getElementById('guestMsg').style.display = 'none';
  checkFeedbackEligibility();
  skipAuth();
}

function logout() {
  google.accounts.id.disableAutoSelect();
  location.reload(); // Simple reload for logout
}

function checkFeedbackEligibility() {
  if (!currentUser) return;
  
  const reviews = JSON.parse(localStorage.getItem('m_reviews') || '[]');
  const alreadyReviewed = reviews.some(r => r.email === currentUser.email);
  
  if (alreadyReviewed) {
    document.getElementById('feedbackInputArea').style.display = 'none';
    document.getElementById('guestMsg').innerText = "Aapne apna review de diya hai. Shukriya! ❤️";
    document.getElementById('guestMsg').style.display = 'block';
  } else {
    document.getElementById('feedbackInputArea').style.display = 'block';
  }
}

function postComm() {
  const msg = document.getElementById('uMsg').value.trim();
  if(!msg || !currentUser) return;

  const reviews = JSON.parse(localStorage.getItem('m_reviews') || '[]');
  reviews.push({ 
    name: currentUser.name, 
    email: currentUser.email, 
    msg: msg,
    date: new Date().toLocaleDateString()
  });
  
  localStorage.setItem('m_reviews', JSON.stringify(reviews));
  document.getElementById('uMsg').value = '';
  
  loadReviews();
  checkFeedbackEligibility();
}

function loadReviews() {
  const reviews = JSON.parse(localStorage.getItem('m_reviews') || '[]');
  const list = document.getElementById('commList');
  
  if (reviews.length === 0) {
    list.innerHTML = `<p style="text-align:center; color:var(--muted); font-size:0.8rem;">Abhi koi review nahi hai.</p>`;
    return;
  }

  list.innerHTML = reviews.slice().reverse().map(r => `
    <div class="comm-item">
      <strong>${r.name} <span style="font-size:0.6rem; color:#ccc;">• ${r.date}</span></strong>
      <p>${r.msg}</p>
    </div>
  `).join('');
}

window.onload = loadReviews;
</script>

</body>
</html>
